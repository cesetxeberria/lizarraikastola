ui menu.c32
prompt 0
default Gela64
timeout 20

label Gela64
 menu clear
 kernel tftp/livecds/gela/vmlinuz
 initrd tftp/livecds/gela/initrd.img
 append panic=10 ro boot=live root=/dev/nfs nfsroot={{ ansible_default_ipv4.address }}:{{ tftp_root }}/livecds/gela swap mitigations=off
 ipappend 2 

label Gela32
 menu clear
 kernel tftp/livecds/gela32/vmlinuz
 initrd tftp/livecds/gela32/initrd.img
 append panic=10 ro boot=live root=/dev/nfs nfsroot={{ ansible_default_ipv4.address }}:{{ tftp_root }}/livecds/gela32 swap mitigations=off
 ipappend 2 

label Zerbitzaria64
 menu clear
 kernel tftp/livecds/zerbitzaria/vmlinuz
 initrd tftp/livecds/zerbitzaria/initrd.img
 append panic=10 ro boot=live root=/dev/nfs nfsroot={{ ansible_default_ipv4.address }}:{{ tftp_root }}/livecds/zerbitzaria swap mitigations=off
 ipappend 2 

label Zerbitzaria32
 menu clear
 kernel tftp/livecds/zerbitzaria32/vmlinuz
 initrd tftp/livecds/zerbitzaria32/initrd.img
 append panic=10 ro boot=live root=/dev/nfs nfsroot={{ ansible_default_ipv4.address }}:{{ tftp_root }}/livecds/zerbitzaria32 swap mitigations=off
 ipappend 2 

label Debian instalatzailea (amd64)
 menu clear
 kernel tftp/installers/debian/amd64/linux
 initrd tftp/installers/debian/amd64/initrd.gz
 append vga=788 --- quiet

label Debian instalatzailea (i386)
 menu clear
 kernel tftp/installers/debian/i386/linux
 initrd tftp/installers/debian/i386/initrd.gz
 append vga=788 --- quiet

label Windows PE wimboot
 com32 linux.c32
 append tftp/windows/wimboot initrdfile=tftp/windows/bcd,tftp/windows/boot.sdi,tftp/windows/boot.wim

label Windows PE memdisk
 kernel tftp/windows/memdisk  
 initrd tftp/windows/winpe.img    
 append raw

label Localboot
 localboot 0
